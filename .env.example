# NCERT DNA AI - Production Environment Variables Configuration

# Server Port
PORT=3000

# Application URL
APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# MongoDB Connection String (Atlas or Cloud hosted)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ncert_dna?retryWrites=true&w=majority

# Gemini Cognitive Intelligence API Secret
GEMINI_API_KEY=

# JWT Symmetric Secret for Authentication Handshake
JWT_SECRET=super-secret-jwt-key-for-ncert-dna-3122

# Google Cloud Storage Settings
GCS_BUCKET_NAME=ncert-dna-uploads-bucket
GOOGLE_APPLICATION_CREDENTIALS=
